APP_ENV=production
PROJECT_NAME=RealtyScope
LOG_LEVEL=INFO

APP_DOMAIN=realtyscope.bond
API_DOMAIN=api.realtyscope.bond
ACME_EMAIL=you@example.com
STREAMLIT_API_BASE_URL=https://api.realtyscope.bond
STREAMLIT_API_TIMEOUT_SECONDS=30
STREAMLIT_INITIAL_LISTING_ROW_LIMIT=20000
STREAMLIT_INITIAL_MAP_POINT_LIMIT=20000

POSTGRES_USER=realtyscope
POSTGRES_PASSWORD=change-this-long-random-password
POSTGRES_DB=realtyscope
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

MLFLOW_TRACKING_URI=http://mlflow:5000
ACTIVE_MODEL_NAME=realtyscope-price-model
ACTIVE_MODEL_ARTIFACT_PATH=data/processed/models/phase5/selected_price_model_v1_non_leaky.joblib

# Dockerized scheduled ingestion job. This job ingests a bounded Domclick snapshot
# already present on the VPS; live Chrome/CDP capture requires a Chrome-capable host
# and a source-access route.
DOMCLICK_SOURCE_PATH=data/raw/domclick/current
DOMCLICK_MAX_RECORDS=2000
DOMCLICK_MIN_RECORDS=1
DOMCLICK_MIN_NORMALIZED_RECORDS=1000
